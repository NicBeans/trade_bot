# Trading Mode: "testnet" or "mainnet"
TRADING_MODE=testnet

# Binance Testnet API Keys
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret

# Binance Mainnet API Keys
BINANCE_MAINNET_API_KEY=your_mainnet_api_key
BINANCE_MAINNET_API_SECRET=your_mainnet_api_secret

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://tradebot:tradebot@localhost:5432/tradebot

# Discord Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Risk Preset: "conservative", "moderate", "aggressive"
RISK_PRESET=moderate

# Bot Mode: "supervised" or "autonomous"
BOT_MODE=supervised

# Trading capital cap (mainnet, in USDT)
TRADING_CAPITAL=20.0

# Risk parameter overrides (uncomment to override preset values)
# OVERRIDE_GRID_LEVELS=10
# OVERRIDE_GRID_RANGE_PCT=0.05
# OVERRIDE_STOP_LOSS_PCT=0.10
# OVERRIDE_MAX_CAPITAL_PER_LEVEL_PCT=0.10
# OVERRIDE_GRID_RESET_COOLDOWN_SECONDS=600
# OVERRIDE_PAUSE_ON_RANGE_EXIT=false
